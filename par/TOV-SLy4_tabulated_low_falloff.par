# .-------------------------------------------------.
# | Baikal+IllinoisGRMHD Tabulated SLy4 EOS TOV run |
# .-------------------------------------------------.
#
#-------------Thorn activation-------------
ActiveThorns = "

  ADMBase
  ADMCoupling
  ADMMacros
  AEILocalInterp
  Baikal
  Boundary
  Carpet
  CarpetInterp
  CarpetIOASCII
  CarpetIOBasic
  CarpetIOHDF5
  CarpetIOScalar
  CarpetLib
  CarpetReduce
  CarpetRegrid2
  CarpetSlab
  CartGrid3D
  CoordBase
  CoordGauge
  Convert_to_HydroBase
  EOS_Base
  EOS_Omni
  GenericFD
  GSL
  HDF5
  HydroBase
  ID_converter_ILGRMHD
  ID_TabEOS_HydroQuantities
  IllinoisGRMHD
  InitBase
  IOUtil
  LORENE
  LocalInterp
  LocalReduce
  LoopControl
  MoL
  MPI
  NaNChecker
  NewRad
#  NRPyLeakageET
  NRPyPlusTOVID
  Seed_Magnetic_Fields
  Slab
  SpaceMask
  StaticConformal
  SummationByParts
  SymBase
  TerminationTrigger
  Time
  TmunuBase
  Vectors

"

#---------Cactus---------
Cactus::cctk_run_title     = "Baikal_IGM_SLy4_TOV"
Cactus::cctk_full_warnings = "yes"
Cactus::terminate          = "iteration"
Cactus::cctk_itlast				 = 20

#---------ADMBase---------
ADMBase::evolution_method         = "Baikal"
ADMBase::lapse_evolution_method   = "Baikal"
ADMBase::shift_evolution_method   = "Baikal"
ADMBase::dtlapse_evolution_method = "Baikal"
ADMBase::dtshift_evolution_method = "Baikal"
ADMBase::initial_data             = "NRPyPlusTOVID"
ADMBase::initial_lapse            = "NRPyPlusTOVID"
ADMBase::initial_shift            = "zero"
ADMBase::initial_dtlapse          = "zero"
ADMBase::initial_dtshift          = "zero"
ADMBase::metric_type              = "physical"
ADMBase::metric_timelevels        = 3
ADMBase::lapse_timelevels         = 3
ADMBase::shift_timelevels         = 3

#---------ADMMacros---------
ADMMacros::spatial_order = 4

#---------Baikal---------
Baikal::diss_strength = 0.2
Baikal::eta           = 1.0/2.782293851369 # M_ADM = 2.782293851369 (from LORENE)

#---------Boundary---------
Boundary::radpower = 2

#---------Carpet---------
Carpet::domain_from_coordbase    = "yes"
Carpet::enable_all_storage       = "no"
Carpet::check_for_poison         = "no"
Carpet::init_fill_timelevels     = "yes"
Carpet::init_3_timelevels        = "no"
Carpet::poison_new_timelevels    = "yes"
Carpet::storage_verbose          = "no"
Carpet::use_buffer_zones         = "yes"
Carpet::verbose                  = "no"
Carpet::veryverbose              = "no"
Carpet::convergence_level        = 0
Carpet::ghost_size               = 3
Carpet::output_timers_every      = 512
Carpet::prolongation_order_space = 5
Carpet::prolongation_order_time  = 2
Carpet::max_refinement_levels    = 4 # 5 # <- This will set the regrid/output frequency
#Carpet::time_refinement_factors  = "[1,2,4,8,16]"

#---------CarpetInterp---------
CarpetInterp::check_tree_search = "no"
CarpetInterp::tree_search       = "yes"

#---------CarpetLib---------
CarpetLib::support_staggered_operators = "yes"
CarpetLib::combine_recompose           = "no"
CarpetLib::print_memstats_every        = -1

#---------CarpetRegrid2---------
CarpetRegrid2::freeze_unaligned_levels = "yes"
CarpetRegrid2::symmetry_rotating180    = "no"
CarpetRegrid2::verbose                 = "no"
CarpetRegrid2::num_centres             = 1

# Grid #1: centered at "left" star
# The values below are set to match Spritz
CarpetRegrid2::num_levels_1 = 4
CarpetRegrid2::radius_1[1]  = 72
CarpetRegrid2::radius_1[2]  = 36
CarpetRegrid2::radius_1[3]  = 18
#CarpetRegrid2::radius_1[4]  = 9

#---------CartGrid3D---------
CartGrid3D::avoid_origin = "no"
CartGrid3D::type         = "CoordBase"

#---------CoordBase---------
CoordBase::boundary_size_x_lower = 3
CoordBase::boundary_size_y_lower = 3
CoordBase::boundary_size_z_lower = 3
CoordBase::boundary_size_x_upper = 3
CoordBase::boundary_size_y_upper = 3
CoordBase::boundary_size_z_upper = 3
CoordBase::domainsize            = "minmax"
CoordBase::spacing               = "gridspacing"

# The values below are set to match Spritz
CoordBase::dx   = 3.0
CoordBase::dy   = CoordBase::dx
CoordBase::dz   = CoordBase::dx
CoordBase::xmin = -144 + CoordBase::dx/32.0
CoordBase::xmax = +144 + CoordBase::dx/32.0
CoordBase::ymin = CoordBase::xmin
CoordBase::ymax = CoordBase::xmax
CoordBase::zmin = CoordBase::xmin
CoordBase::zmax = CoordBase::xmax

#---------Convert_to_HydroBase---------
Convert_to_HydroBase::Convert_to_HydroBase_every = 2**Carpet::max_refinement_levels

#---------EOS_Omni---------
EOS_Omni::nuceos_read_table = "yes"
EOS_Omni::nuceos_table_name = "SLy4_3335_rho391_temp163_ye66_adjusted.h5"
EOS_Omni::do_energy_shift   = "yes"

#---------HydroBase---------
HydroBase::initial_hydro       = "NRPyPlusTOVID"
HydroBase::initial_Y_e         = "ID_TabEOS_HydroQuantities"
HydroBase::initial_temperature = "ID_TabEOS_HydroQuantities"
HydroBase::initial_entropy     = "ID_TabEOS_HydroQuantities"
HydroBase::timelevels          = 1

#---------ID_TabEOS_HydroQuantities---------
ID_TabEOS_HydroQuantities::atmo_falloff        = "yes"
ID_TabEOS_HydroQuantities::r_atmo_min					 = 10
ID_TabEOS_HydroQuantities::id_temperature_type = "constant"
ID_TabEOS_HydroQuantities::id_entropy_type     = "from table"
ID_TabEOS_HydroQuantities::Y_e_filename        = "Ye_of_rho-SLy4.txt"
ID_TabEOS_HydroQuantities::id_temperature      = 1e-2
ID_TabEOS_HydroQuantities::id_rho_atm_max      = 1e-12
ID_TabEOS_HydroQuantities::id_Y_e_atm          = 0.5
ID_TabEOS_HydroQuantities::id_temperature_atm  = ID_TabEOS_HydroQuantities::id_temperature

#---------IllinoisGRMHD---------
# Setting up the EOS parameters like this
# ensures compatibility with EOS_Omni.
IllinoisGRMHD::igm_PPM_reconstructed_variable = "pressure"
IllinoisGRMHD::igm_con2prim_routine           = "Palenzuela1D"
IllinoisGRMHD::igm_con2prim_backup_routine[0] = "Newman1D"
IllinoisGRMHD::igm_eos_type                   = "Tabulated"
IllinoisGRMHD::igm_evolve_temperature         = "yes"
IllinoisGRMHD::igm_evolve_entropy             = "yes"
IllinoisGRMHD::atmo_falloff										= ID_TabEOS_HydroQuantities::atmo_falloff
IllinoisGRMHD::r_atmo_min											= ID_TabEOS_HydroQuantities::r_atmo_min
IllinoisGRMHD::rho_b_atm_max                  = ID_TabEOS_HydroQuantities::id_rho_atm_max
IllinoisGRMHD::igm_Ye_atm                     = ID_TabEOS_HydroQuantities::id_Y_e_atm
IllinoisGRMHD::igm_T_atm                      = ID_TabEOS_HydroQuantities::id_temperature_atm
IllinoisGRMHD::conserv_to_prims_debug         = 0
IllinoisGRMHD::Psi6threshold                  = 60
IllinoisGRMHD::damp_lorenz                    = 0.0
IllinoisGRMHD::palenzuela_depsdT_threshold    = 1e-100 # Set to 1e100/1e-100 to only use entropy/energy equation
IllinoisGRMHD::igm_eos_table_floor_safety_factor = 1.0
IllinoisGRMHD::igm_eos_table_ceiling_safety_factor = 1.0
IllinoisGRMHD::tau_atm_hybrid                        = -9.553427062636353e-15

#---------InitBase---------
InitBase::initial_data_setup_method = "init_some_levels"

#---------MoL---------
MoL::run_MoL_PostStep_in_Post_Recover_Variables = "no"
MoL::ODE_Method                                 = "rk4"
MoL::MoL_Intermediate_Steps                     = 4
MoL::MoL_Num_Scratch_Levels                     = 1

#---------NaNChecker---------
NaNChecker::verbose         = "all"
NaNChecker::action_if_found = "terminate"
NaNChecker::check_every     = 1024
NaNChecker::check_vars      = "ADMBase::metric ADMBase::lapse ADMBase::shift"

#---------NRPyLeakageET---------
#NRPyLeakageET::verbosity_level              = 2
#NRPyLeakageET::optical_depth_evolution_type = "PathOfLeastResistance"
#NRPyLeakageET::numberOfIterations           = 256
#NRPyLeakageET::minInitRefLevel              = Carpet::max_refinement_levels-1 # Only initialize finest refinement level
#NRPyLeakageET::maxInitRefLevel              = Carpet::max_refinement_levels-1 # Only initialize finest refinement level

#---------NRPyPlusTOVID---------
NRPyPlusTOVID::TOV_filename     = "outputTOVtabulated-SLy4.txt"
NRPyPlusTOVID::rho_atmosphere   = IllinoisGRMHD::rho_b_atm_max
NRPyPlusTOVID::K_atmosphere     = 1
NRPyPlusTOVID::Gamma_atmosphere = 1

#---------Seed_Magnetic_Fields---------
Seed_Magnetic_Fields::enable_IllinoisGRMHD_staggered_A_fields = "yes"
Seed_Magnetic_Fields::A_b                                     = 0.00000000000000000000000000 # <- SET TO ZERO INITIAL MAGNETIC FIELDS.

#---------SpaceMask---------
SpaceMask::use_mask = "yes"

#---------TerminationTrigger---------
TerminationTrigger::create_termination_file = "yes"
TerminationTrigger::termination_from_file   = "yes"
TerminationTrigger::termination_file        = "TERMINATE"
TerminationTrigger::max_walltime            = 48 # IN HOURS
TerminationTrigger::on_remaining_walltime   = 60 # IN MINUTES

#---------Time---------
Time::dtfac = 0.5 # == 0.5 (Courant factor) * (1/2)^N_repeats (from time_refinement_factors above)

#---------TmunuBase---------
TmunuBase::stress_energy_storage = yes
TmunuBase::stress_energy_at_RHS  = yes
TmunuBase::timelevels            =  1
TmunuBase::prolongation_type     = none

# .----------------------.
# | Output configuration |
# .----------------------.

#---------IOUtil---------
IOUtil::out_dir                         = "$parfile"
IOUtil::checkpoint_dir                  = "$parfile/checkpoints"
IOUtil::recover_dir                     = "$parfile/checkpoints"
IOUtil::checkpoint_keep                 = 1
IOUtil::checkpoint_on_terminate         = "yes"
IOUtil::out_fileinfo                    = "none"
IOUtil::parfile_write                   = "generate"
IOUtil::recover                         = "autoprobe"
IOUtil::checkpoint_every_walltime_hours = 12

#---------CarpetIOASCII---------
CarpetIOASCII::one_file_per_group = "yes"
CarpetIOASCII::out0D_every        = 1
CarpetIOASCII::out0D_vars         = "
  Carpet::physical_time_per_hour
  # QuasiLocalMeasures::qlm_scalars 
  # SphericalSurface::sf_active
"
CarpetIOASCII::out1D_d     = "no"
CarpetIOASCII::out1D_dir   = "$parfile/ascii_1d"
CarpetIOASCII::out1D_every = 1
CarpetIOASCII::out1D_vars  = "
  IllinoisGRMHD::rho_b
  IllinoisGRMHD::igm_Ye
  IllinoisGRMHD::igm_temperature
  IllinoisGRMHD::igm_eps
  IllinoisGRMHD::igm_entropy
  IllinoisGRMHD::P
#  IllinoisGRMHD::vx
#  IllinoisGRMHD::vy
#  IllinoisGRMHD::vz
#  IllinoisGRMHD::Ax
#  IllinoisGRMHD::Ay
#  IllinoisGRMHD::Az
#  IllinoisGRMHD::Bx
#  IllinoisGRMHD::By
#  IllinoisGRMHD::Bz
  ADMBase::lapse
  Baikal::HGF
  Baikal::MU0GF
  Baikal::MU1GF
  Baikal::MU2GF
"
CarpetIOASCII::out2D_dir   = "$parfile/ascii_2d"
CarpetIOASCII::out2D_every = 1
CarpetIOASCII::out2D_vars  = "
  IllinoisGRMHD::rho_b
  IllinoisGRMHD::igm_Ye
  IllinoisGRMHD::igm_temperature
  IllinoisGRMHD::igm_eps
  IllinoisGRMHD::igm_entropy
  IllinoisGRMHD::P
#  IllinoisGRMHD::vx
#  IllinoisGRMHD::vy
#  IllinoisGRMHD::vz
#  IllinoisGRMHD::Bx
#  IllinoisGRMHD::By
#  IllinoisGRMHD::Bz
  Baikal::HGF
  Baikal::MU0GF
  Baikal::MU1GF
  Baikal::MU2GF
"
CarpetIOASCII::out3D_ghosts           = "no"
CarpetIOASCII::output_symmetry_points = "no"

# Parameters of thorn CarpetIOBasic (implementing IOBasic)
CarpetIOBasic::outInfo_every      = 1
CarpetIOBasic::outInfo_reductions = "maximum"
CarpetIOBasic::outInfo_vars       = "
  Carpet::physical_time_per_hour
  Baikal::trKGF
  Baikal::cfGF
  IllinoisGRMHD::rho_b
  IllinoisGRMHD::failure_checker
"

#---------CarpetIOHDF5---------
CarpetIOHDF5::checkpoint         = "yes"
CarpetIOHDF5::compression_level  = 0
CarpetIOHDF5::one_file_per_group            = "yes"
CarpetIOHDF5::out2D_every                   = 1
CarpetIOHDF5::out2D_vars                    = "
  ADMBase::metric
  ADMBase::lapse
  ADMBase::shift
  IllinoisGRMHD::grmhd_primitives_allbutBi
  IllinoisGRMHD::grmhd_primitives_Bi
  IllinoisGRMHD::grmhd_conservatives
  IllinoisGRMHD::grmhd_conservatives_rhs
  Baikal::HGF
"


#---------CarpetIOScalar---------
CarpetIOScalar::one_file_per_group   = "no"
CarpetIOScalar::outScalar_every      = 2**Carpet::max_refinement_levels
CarpetIOScalar::outScalar_reductions = "minimum maximum average"
CarpetIOScalar::outScalar_vars       = "
  ADMBase::alp
  IllinoisGRMHD::rho_b
  IllinoisGRMHD::igm_Ye
  IllinoisGRMHD::igm_temperature
  IllinoisGRMHD::P
  IllinoisGRMHD::igm_eps
  IllinoisGRMHD::igm_entropy
"
