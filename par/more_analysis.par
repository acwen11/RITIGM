#============= Info output =======================================
CarpetIOBasic::outInfo_criterion              = "divisor"

# ===============================
# MARKER: SET INFO       
# ===============================
CarpetIOBasic::outInfo_every			= 768
#=================================================================

#============= Scalar and 0D output ==============================
CarpetIOScalar::outScalar_criterion           = "divisor"
CarpetIOScalar::outScalar_dir                 = "data_Scalar"

# ===============================
# MARKER: SET SCALAR       
# ===============================
CarpetIOScalar::outScalar_every               = 768

CarpetIOScalar::outScalar_reductions          = "norm_inf minimum maximum norm1 norm2 average"

CarpetIOASCII::out0D_criterion                = "divisor"
CarpetIOASCII::out0D_dir                      = "data_asc_0D"

# ===============================
# MARKER: SET 0D       
# ===============================
CarpetIOASCII::out0D_every                    = 768

#=================================================================

#==================  Domain output  ==============================
CarpetIOHDF5::out1D_criterion                 = "divisor"
CarpetIOHDF5::out1D_dir                       = "data_hdf5_1D"

# ===============================
# MARKER: SET 1D        
# ===============================
CarpetIOHDF5::out1D_every                        = -1


CarpetIOHDF5::out2D_criterion                 = "divisor"
CarpetIOHDF5::out2D_dir                       = "data_hdf5_2D"
CarpetIOHDF5::out2D_xz		              = yes
CarpetIOHDF5::out2D_yz		              = no
CarpetIOHDF5::out2D_xy			      = yes

# ===============================
# MARKER: SET 2D      
# ===============================
CarpetIOHDF5::out2D_every                     = 768

# ===============================
# MARKER: CHECK PLANE       
# ===============================
CarpetIOHDF5::out2D_xyplane_z                 = 0.7

CarpetIOHDF5::out3D_criterion                    = "divisor"
CarpetIOHDF5::out3D_dir                          = "data_hdf5_3D"

# ===============================
# MARKER: SET 3D   
#         13824 * 0.0047 M = 65.45 M
#         13824/768        = 18
#         13824/128        = 108        
# ===============================
CarpetIOHDF5::out3D_every                        = 13824

#=================================================================

#==================  General output settings =======================
IOUtil::strict_io_parameter_check = "yes"
IOUtil::parfile_write             = "copy"

# To reduce the number of files 0n the output directory
CarpetIOScalar::all_reductions_in_one_file    = "no"
CarpetIOScalar::one_file_per_group            = "no"
CarpetIOASCII::one_file_per_group             = "yes"
CarpetIOHDF5::one_file_per_group              = "no"

