######################## Grid setup ########################################


ActiveThorns = "Boundary CartGrid3D CoordBase SymBase"

CoordBase::domainsize = "minmax"

CoordBase::xmin =  -1000.00              # multiply with ~1.477 for km 
CoordBase::ymin =  -1000.00
CoordBase::zmin =     0.00
CoordBase::xmax =   1000.00
CoordBase::ymax =   1000.00
CoordBase::zmax =   1000.00

CoordBase::spacing = "numcells"
CoordBase::ncells_x			=  660
CoordBase::ncells_y			=  660
CoordBase::ncells_z			=  330

# ===============================
# MARKER: 2000/660 * 1.48 = 4.48km
# ===============================

CoordBase::boundary_size_x_lower     = 4
CoordBase::boundary_size_y_lower     = 4
CoordBase::boundary_size_z_lower     = 4
CoordBase::boundary_size_x_upper     = 4
CoordBase::boundary_size_y_upper     = 4
CoordBase::boundary_size_z_upper     = 4


CoordBase::boundary_shiftout_z_lower =1
CartGrid3D::type = "coordbase"
CartGrid3D::domain       = "full"
CartGrid3D::avoid_origin = "no"

ActiveThorns = "ReflectionSymmetry"
ReflectionSymmetry::reflection_z = yes
ReflectionSymmetry::avoid_origin_z = no
IllinoisGRMHD::Symmetry = "equatorial"

#=============== Refinement =====================
ActiveThorns = "CarpetRegrid2"

# ===============================
# MARKER: 2000/660/2^7 * 1.48 = 0.035km
# ===============================

Carpet::max_refinement_levels=8

CarpetRegrid2::num_centres  = 3

# ===============================
# MARKER: Every 2^(ref_levels -1) 
# iterations the whole grid is 
# updated by the coarsest timestep:
# 8 levels -> 2^7= 128!
# ===============================

CarpetRegrid2::regrid_every = 128  

CarpetRegrid2::snap_to_coarse = yes
CarpetRegrid2::ensure_proper_nesting		= "yes"
CarpetRegrid2::freeze_unaligned_levels		= "yes"
CarpetRegrid2::freeze_unaligned_parent_levels	= "yes"

